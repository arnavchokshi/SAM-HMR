# Run outputs (large; reproducible from data + scripts).
# Use runs/* (not runs/) so the !exception below can re-include the agent log.
runs/*
!runs/3d_compare/
runs/3d_compare/*
!runs/3d_compare/_agent_log.md
!runs/3d_compare/REPORT.md
!runs/3d_compare/HANDOFF_FOR_NEXT_AGENT.md

# Weights / model checkpoints (large; fetched via scripts/fetch_*.sh)
weights/
data/pretrain/

# Shift 7 — HaMeR per-track hand recovery
# Cloned at runtime on the GH200; do not commit (~3 GB w/ submodules).
third_party/hamer/
# HaMeR demo bundle + MANO_RIGHT.pkl (license-gated); fetched by scripts/fetch_hamer_weights.sh
data/pretrain/hamer/
